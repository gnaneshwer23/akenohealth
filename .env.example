# Copy to .env.local for local development. Do not commit secrets.

# Neon Postgres (primary database)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
POSTGRES_DSN=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Service URLs (local defaults)
IDENTITY_CONSENT_URL=http://localhost:8003
INGESTION_API_URL=http://localhost:8001
AI_SAFETY_API_URL=http://localhost:8002

# Optional local infra (when not using Neon for graph/events)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
